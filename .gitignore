node_modules/
dist/
dist-cli/
.vite/
.DS_Store

# playwright
playwright-report/
playwright-report-real/
test-results/
playwright/.cache/
.playwright-browsers/
.tmp/

# vibe-pipeline runtime (session drafts etc, regenerated)
.vibe-pipeline/.runtime/
# pipeline 執行紀錄 — merge 後 redundant 於 git commit chain(每張 ticket 的 ticket(<n>): <title> commit + merge commit
# 已記錄結果),pipeline.json 留的 iter rounds / status 是過程,solo 用沒共享需求
.vibe-pipeline/pipelines/
# self-dogfood config — 對 vibe-pipeline 自身 repo,config.json 是個人化 setup(max_parallel / cost_limit 等),
# user target repo 設計上應 git tracked(CLAUDE.md § Repo 外),但這 repo 本身的 self-dogfood 不該散
.vibe-pipeline/config.json

# perf bench output(benchmark 跑出來的 results,當時量測用,不該 track)
.perf-bench/

# tsc emit (build via Vite, no separate emit needed)
*.tsbuildinfo
src/**/*.js
src/**/*.js.map
server/**/*.js
server/**/*.js.map
shared/**/*.js
shared/**/*.js.map
tests/**/*.js
tests/**/*.js.map
!tests/**/*.mjs

# logs
*.log
npm-debug.log*

# env
.env
.env.*
!.env.example
firebase-service-account*.json

# FCM scratch / Firebase config (service account JSON、VAPID 抄寫等)
.fcm/

# editors
.vscode/
.idea/
*.swp
*.swo

# /loop runtime lock
.claude/scheduled_tasks.lock
