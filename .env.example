# Set to "1" to bypass TOTP auth middleware entirely (testing only, never in production)
VP_DISABLE_AUTH=

# Comma-separated extra allowed CORS origins (e.g. Tailscale peers)
ALLOWED_ORIGINS=
# Set to http://<tailscale-ip>:3001 when accessing from a remote device; leave empty for local dev
VITE_API_BASE_URL=

# Push:enduser 不必設任何欄位。VP backend 預設打 maintainer 公開 gateway,
# Firebase Web SDK config(frontend / SW)亦 hardcode 在 src/lib/fcm.ts 內。
#
# 想自架 gateway / Firebase project(forker 用)才開以下:
#   PUSH_GATEWAY_URL=https://your-gateway.example.com
#   VITE_FCM_API_KEY=...
#   VITE_FCM_AUTH_DOMAIN=...
#   VITE_FCM_PROJECT_ID=...
#   VITE_FCM_STORAGE_BUCKET=...
#   VITE_FCM_MESSAGING_SENDER_ID=...
#   VITE_FCM_APP_ID=...
#   VITE_FCM_VAPID_KEY=...
