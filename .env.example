# Set to "1" to bypass TOTP auth middleware entirely (testing only, never in production)
VP_DISABLE_AUTH=

# Comma-separated extra allowed CORS origins (e.g. Tailscale peers)
ALLOWED_ORIGINS=
# Set to http://<tailscale-ip>:3001 when accessing from a remote device; leave empty for local dev
VITE_API_BASE_URL=
# Push Gateway(maintainer host;service account 集中在 gateway 端,VP backend 只持有 enduser token)
# 預設指向 maintainer 公開 gateway;若想自架 gateway 改 URL,token 走 ~/.vibe-pipeline/gateway-token 自動管理不必設。
PUSH_GATEWAY_URL=
# Firebase Web SDK config (for frontend + service worker;public,SW init firebase 用)
FCM_API_KEY=
FCM_AUTH_DOMAIN=
FCM_PROJECT_ID=
FCM_STORAGE_BUCKET=
FCM_MESSAGING_SENDER_ID=
FCM_APP_ID=
FCM_VAPID_KEY=
