{
  "name": "vibe-pipeline",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n vite,bun -c blue,yellow \"vite\" \"bun run server/index.ts\"",
    "server": "bun run server/index.ts",
    "preview": "vite preview --port 4173",
    "sub:dev": "concurrently -n vite,bun -c blue,yellow \"cross-env VITE_E2E_API_TARGET=http://127.0.0.1:3101 vite --port 5273\" \"cross-env PORT=3101 bun run server/index.ts\"",
    "sub:server": "cross-env PORT=3101 bun run server/index.ts",
    "sub:preview": "cross-env VITE_E2E_API_TARGET=http://127.0.0.1:3101 vite preview --port 4273",
    "build": "tsc -b && vite build",
    "lint": "biome lint",
    "lint:fix": "biome lint --write",
    "test:e2e": "playwright test --config=tests/e2e/playwright.config.ts",
    "test:e2e:real": "playwright test --config=tests/e2e/playwright.real.config.ts",
    "icons": "bun run scripts/gen-icons.ts",
    "vbpl": "bun run cli/vbpl.ts",
    "cli:build": "bun build --compile --minify --target=bun-windows-x64 cli/vbpl.ts --outfile dist-cli/vbpl.exe",
    "cli:build:mac": "bun build --compile --minify --target=bun-darwin-arm64 cli/vbpl.ts --outfile dist-cli/vbpl-mac",
    "cli:build:linux": "bun build --compile --minify --target=bun-linux-x64 cli/vbpl.ts --outfile dist-cli/vbpl-linux"
  },
  "dependencies": {
    "firebase": "^12.13.0",
    "firebase-admin": "^13.9.0",
    "otpauth": "^9.5.1",
    "qrcode-svg": "^1.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.28.0",
    "workbox-cacheable-response": "^7.4.1",
    "workbox-expiration": "^7.4.1",
    "workbox-routing": "^7.4.1",
    "workbox-strategies": "^7.4.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@playwright/test": "^1.59.1",
    "@types/bun": "^1.1.12",
    "@types/qrcode-svg": "^1.1.5",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "concurrently": "^9.1.0",
    "cross-env": "^10.1.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vite-plugin-pwa": "^1.3.0",
    "workbox-precaching": "^7.4.1",
    "workbox-window": "^7.4.1"
  }
}
