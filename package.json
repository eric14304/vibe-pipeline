{
  "name": "vibe-pipeline",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "server": "bun run --watch server/index.ts",
    "dev:all": "concurrently -n vite,bun -c blue,yellow \"bun run dev\" \"bun run server\"",
    "build": "tsc -b && vite build",
    "preview": "vite preview --port 4173",
    "lint": "biome lint",
    "lint:fix": "biome lint --write",
    "test:e2e": "playwright test --config=tests/e2e/playwright.config.ts",
    "test:e2e:real": "playwright test --config=tests/e2e/playwright.real.config.ts"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.28.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@playwright/test": "^1.59.1",
    "@types/bun": "^1.1.12",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "concurrently": "^9.1.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}
